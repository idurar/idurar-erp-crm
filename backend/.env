# ============================
# MongoDB
# ============================
DATABASE=mongodb://localhost:27017/example_db

# ============================
# JWT Secrets (Use your own strong random values)
# ============================
JWT_ACCESS_SECRET=dummy_access_secret_key_1234567890
JWT_REFRESH_SECRET=dummy_refresh_secret_key_0987654321

# ============================
# Token Expiry Durations
# ============================
JWT_ACCESS_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ============================
# Required Configuration
# ============================
NODE_ENV=development
OPENSSL_CONF=/dev/null
PUBLIC_SERVER_FILE=http://localhost:8888/

# ============================
# Optional (Disable email requirement or for test mode)
# ============================
RESEND_API=dummy_resend_api_key
OPENAI_API_KEY=dummy_openai_api_key
